---
interface Item {
  href: string;
  title: string;
  kind?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <div class="related">
    {items.map((item) => (
      <a href={item.href}>
        <span class="rt">{item.title}</span>
        <span class="rk">{item.kind ?? 'Related'} →</span>
      </a>
    ))}
  </div>
)}
