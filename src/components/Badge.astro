---
interface Props {
  status: 'idea' | 'work-in-progress' | 'completed' | 'archived' | string;
  label?: string;
}

const labels: Record<string, string> = {
  idea: 'Idea',
  'work-in-progress': 'Work In Progress',
  completed: 'Completed',
  archived: 'Archived',
};

const { status, label = labels[Astro.props.status] ?? Astro.props.status } = Astro.props;
---

<span class:list={['badge', `st-${status}`]}><i class="d"></i>{label}</span>
