---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Panel from '../components/Panel.astro';
import Pipeline from '../components/Pipeline.astro';
import { formatDate, getFeaturedProjects, getLatestWeeklyBrief, getRecentNotes, validateContentLinks } from '../lib/content';

await validateContentLinks();

const [featuredProjects, recentNotes, weeklyBrief] = await Promise.all([
  getFeaturedProjects(),
  getRecentNotes(4),
  getLatestWeeklyBrief(),
]);

function compactSummary(summary?: string, maxLength = 100) {
  if (!summary) return '';
  const normalized = summary.replace(/\s+/g, ' ').trim();
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trimEnd()}...`;
}
---

<BaseLayout title="Junu's Lab">
  <section class="hero">
    <Eyebrow text="Interested in CV / ML Research Collaboration" />
    <h1>Computer Vision</h1>
    <div class="sub">Research-oriented Builder</div>
    <p class="lede">
      I am an undergraduate student in IT Management at SeoulTech.
    </p>
    <p class="lede">
      I build projects and research notes around computer vision, machine learning, and animal behavior analysis, with a long-term interest in understanding animal behavior from raw video.
    </p>
    <div class="hashrow">
      <span># Computer Vision</span>
      <span># Machine Learning</span>
      <span># Animal Behavior Analysis</span>
      <span># Pose Estimation</span>
      <span># Video Understanding</span>
      <span># Annotation Automation</span>
    </div>
    <div class="cta-row">
      <a class="btn primary" href="/projects/">View Projects</a>
      <a class="btn" href="/notes/">Read Lab Notes</a>
      <a class="btn btn-icon" href="/contact/"><span class="mail-icon" aria-hidden="true"></span>Contact</a>
    </div>
  </section>

  <section class="home-row">
    <Panel title="Current Focus">
      <div class="focus-grid">
        <div class="focus-item"><span>Animal behavior video understanding</span><div class="bar"><i style="width:86%"></i></div><span class="lvl">active</span></div>
        <div class="focus-item"><span>Weak / semi-supervised labeling</span><div class="bar"><i style="width:72%"></i></div><span class="lvl">active</span></div>
        <div class="focus-item"><span>Reproducible ML project workflow</span><div class="bar"><i style="width:64%"></i></div><span class="lvl">steady</span></div>
      </div>
    </Panel>
    <Panel title="Lab Status">
      <div class="status-rows">
        <div class="row"><span class="k">Reading</span><span class="v">semi-supervised behavior recognition</span></div>
        <div class="row"><span class="k">Experimenting</span><span class="v on">Be MOre Duck / ArchiTag<br /><span class="muted">wildlife vision and annotation workflow prototypes</span></span></div>
        <div class="row"><span class="k">Next</span><span class="v">labeling automation prototype</span></div>
      </div>
    </Panel>
  </section>

  <section class="block-head">
    <Eyebrow text="Research Radar" />
    <h2>Weekly Lab Brief routine</h2>
    <p>Weekly Lab Brief is a research tracking workflow that filters raw paper scans into selected reviews, experiment ideas, and project links.</p>
  </section>
  <section class="panel radar">
    <Pipeline steps={['Raw scan', 'Notion inbox', 'Agenda filter', 'Selected review', 'Experiment log']} />
    <div class="radar-grid">
      <div class="col">
        <h4>Tracked Fields</h4>
        <ul>
          <li>Animal behavior analysis</li>
          <li>Pose and keypoint methods</li>
          <li>Video understanding</li>
          <li>Labeling automation</li>
        </ul>
      </div>
      <div class="col">
        <h4>Outputs</h4>
        <ul>
          <li>Selected paper reviews</li>
          <li>Experiment logs</li>
          <li>Mini project candidates</li>
          <li>Project links</li>
        </ul>
      </div>
      <div class="col">
        <h4>Research Direction</h4>
        <p class="sourcebox">Raw animal video -> pose estimation -> behavior recognition -> behavior prediction.</p>
      </div>
    </div>
  </section>

  <section class="block-head">
    <Eyebrow text="Latest Outputs" />
    <h2>Featured Projects</h2>
    <p>Projects from Notion, selected with the Featured property and sorted by project date.</p>
  </section>
  {featuredProjects.length > 0 ? (
    <div class="grid cols-2">
      {featuredProjects.map((project) => (
        <Card href={`/projects/${project.data.slug}/`} title={project.data.title} status={project.data.status} summary={project.data.problem ?? project.data.summary} tags={project.data.domain} meta={project.data.group} />
      ))}
    </div>
  ) : (
    <section class="panel"><p class="muted">No featured projects selected yet.</p></section>
  )}

  <section class="home-row">
    <Panel title="Latest Brief">
      <p class="muted">Latest Weekly Lab Brief</p>
      {weeklyBrief ? (
        <a class="mini-item" href={`/notes/${weeklyBrief.data.slug}/`}>
          <span>
            <span class="mini-title">{weeklyBrief.data.title}</span>
            {weeklyBrief.data.summary && <span class="mini-desc">{compactSummary(weeklyBrief.data.summary)}</span>}
          </span>
          <span class="mini-meta"><span class="kv">{formatDate(weeklyBrief.data.date)}</span><span class="mini-arrow">Open</span></span>
        </a>
      ) : (
        <p class="sourcebox">No weekly brief yet.</p>
      )}
    </Panel>
    <Panel title="Recent Lab Notes">
      <p class="muted">Recent Notion Notes</p>
      {recentNotes.map((note) => (
        <a class="mini-item" href={`/notes/${note.data.slug}/`}>
          <span>
            <span class="mini-title">{note.data.title}</span>
            {note.data.summary && <span class="mini-desc">{compactSummary(note.data.summary)}</span>}
          </span>
          <span class="mini-meta"><span class="kv">{formatDate(note.data.date)}</span><span class="mini-arrow">Open</span></span>
        </a>
      ))}
    </Panel>
  </section>
</BaseLayout>
