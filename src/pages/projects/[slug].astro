---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Metabox from '../../components/Metabox.astro';
import RelatedList from '../../components/RelatedList.astro';
import { resolveNotes, resolveProgram } from '../../lib/content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.data.slug }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const [program, explicitRelatedNotes, notes] = await Promise.all([
  resolveProgram(project.data.program),
  resolveNotes(project.data.relatedNotes),
  getCollection('notes'),
]);
const reverseRelatedNotes = notes.filter((note) => note.data.relatedProject === project.data.slug);
const relatedNotes = [...new Map(
  [...explicitRelatedNotes, ...reverseRelatedNotes].map((note) => [note.data.slug, note]),
).values()];
const links = [
  { label: 'Repository', href: project.data.repo, icon: '{}' },
  { label: 'Deploy', href: project.data.deploy, icon: '>>' },
  { label: 'Demo', href: project.data.demo, icon: 'play' },
  { label: 'Notion', href: project.data.notion, icon: 'N' },
].filter((link) => link.href);
---

<BaseLayout title={`${project.data.title} - Junu's Lab`}>
  <section class="block-head detail-head">
    <Eyebrow text="Project Detail" />
    <h2>{project.data.title}</h2>
    <p>{project.data.problem ?? project.data.summary}</p>
  </section>

  <div class="home-row detail-layout">
    <article class="panel">
      <div class="ctop">
        <Badge status={project.data.status} />
      </div>
      <Metabox items={[
        { label: 'Group', value: project.data.group },
        { label: 'Program', value: program?.title },
        { label: 'Domain', value: project.data.domain },
        { label: 'Stack', value: project.data.stack },
        { label: 'Roles', value: project.data.roles },
        { label: 'Dataset', value: project.data.dataset },
        { label: 'Output', value: project.data.output },
        { label: 'Private repo', value: project.data.repoPrivate ? 'yes' : undefined },
      ]} />
      <div class="dblock notion-content">
        <Content />
      </div>
    </article>
    <aside class="panel project-side">
      {links.length > 0 && (
        <>
          <h3>Links</h3>
          <div class="linkrow side-links">
            {links.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">
                <span class="link-main"><span class="link-icon" aria-hidden="true">{link.icon}</span>{link.label}</span>
              </a>
            ))}
          </div>
          <div class="section-divider"></div>
        </>
      )}
      <nav class="toc" id="projectToc" aria-label="Project page sections" hidden>
        <h3>On this page</h3>
        <div class="toc-list" id="projectTocList"></div>
        <div class="section-divider"></div>
      </nav>
      <h3>Related Lab Notes</h3>
      {program && (
        <div class="selected-note">
          <b>{program.title}</b><br />
          <span class="muted">{program.question}</span>
        </div>
      )}
      <div class="section-divider"></div>
      <RelatedList items={relatedNotes.map((note) => ({
        href: `/notes/${note.data.slug}/`,
        title: note.data.title,
        kind: note.data.type,
      }))} />
    </aside>
  </div>
  <script>
    const content = document.querySelector('.dblock');
    const toc = document.querySelector('#projectToc');
    const tocList = document.querySelector('#projectTocList');
    const headings = Array.from(content?.querySelectorAll('h1, h2') ?? []);

    const slugCounts = new Map();
    const headingLabel = (heading: Element) => {
      const clone = heading.cloneNode(true) as Element;
      clone.querySelectorAll('.katex, script, style').forEach((node) => node.remove());
      return (clone.textContent || heading.textContent || '')
        .replace(/\$\$[\s\S]*?\$\$/g, '')
        .replace(/\$[^$]*\$/g, '')
        .replace(/\\[a-zA-Z]+(?:\{[^}]*\})?/g, '')
        .replace(/\s+/g, ' ')
        .trim();
    };
    const slugify = (value: string | null) => {
      const base = String(value || '')
        .normalize('NFKD')
        .toLowerCase()
        .replace(/[^\w\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-') || 'section';
      const count = slugCounts.get(base) || 0;
      slugCounts.set(base, count + 1);
      return count ? `${base}-${count + 1}` : base;
    };

    if (toc && tocList && headings.length > 0) {
      toc.removeAttribute('hidden');

      for (const heading of headings) {
        const label = headingLabel(heading) || 'Section';
        if (!heading.id) heading.id = slugify(label);
        const link = document.createElement('a');
        link.href = `#${heading.id}`;
        link.textContent = label;
        link.className = heading.tagName === 'H2' ? 'toc-link toc-h2' : 'toc-link toc-h1';
        tocList.append(link);
      }

      const links = Array.from(tocList.querySelectorAll('a'));
      const byId = new Map(links.map((link) => [link.getAttribute('href')?.slice(1), link]));
      const observer = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
        if (!visible) return;

        links.forEach((link) => link.classList.remove('active'));
        byId.get(visible.target.id)?.classList.add('active');
      }, { rootMargin: '-96px 0px -65% 0px', threshold: 0.01 });

      headings.forEach((heading) => observer.observe(heading));
    }
  </script>
</BaseLayout>
