---
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/Badge.astro';
import Card from '../components/Card.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Panel from '../components/Panel.astro';
import Pipeline from '../components/Pipeline.astro';
import { getAllPrograms, getAllProjects, getProjectsForTrack, getResearchTrackSlug } from '../lib/content';

const trackOrder = ['pose', 'behavior', 'annotation'];
const tracks = (await getAllPrograms()).sort((a, b) => trackOrder.indexOf(a.data.id) - trackOrder.indexOf(b.data.id));
const projects = await getAllProjects();

const projectCountLabel = (trackSlug: string) => {
  const count = getProjectsForTrack(projects, trackSlug).length;
  return `${count} ${count === 1 ? 'project' : 'projects'}`;
};
---

<BaseLayout title="Research - Junu's Lab">
  <section class="block-head">
    <Eyebrow text="Research Agenda" />
    <h2>From raw animal video to behavior understanding</h2>
    <p>This page organizes the research questions behind Junu's Lab: animal pose estimation, behavior recognition, video understanding, and annotation-efficient learning for animal behavior analysis.</p>
  </section>

  <section class="block-head">
    <Eyebrow text="Research Tracks" />
    <h2>Core research tracks</h2>
  </section>
  <div class="grid cols-3">
    {tracks.map((track) => (
      <section class="card">
        <div class="ctop">
          <h3>{track.data.title}</h3>
          <Badge status={track.data.status} label={track.data.statusLabel ?? track.data.status} />
        </div>
        <p class="qline">{track.data.question}</p>
        <p class="body">{track.data.matters}</p>
        <div class="taglist">
          {track.data.methods.map((method) => <span class="tag">{method}</span>)}
        </div>
      </section>
    ))}
  </div>

  <section class="block-head">
    <Eyebrow text="Research Workflow" />
    <h2>From paper tracking to experiment logs</h2>
    <p>Research Radar is the weekly workflow that turns broad scans of papers, repositories, datasets, and benchmarks into selected reviews, experiment ideas, and project updates.</p>
  </section>
  <Panel>
    <Pipeline steps={['Research question', 'Paper / repo scan', 'Agenda filter', 'Selected review', 'Experiment note', 'Project update']} />
    <div class="cadence">
      <div class="c"><div class="when">MON</div><div class="act">Scan papers, repositories, datasets, and benchmarks.</div></div>
      <div class="c"><div class="when">Midweek</div><div class="act">Filter items by fit to the research tracks.</div></div>
      <div class="c"><div class="when">FRI</div><div class="act">Write one selected review, baseline plan, or experiment log.</div></div>
      <div class="c"><div class="when">Weekly</div><div class="act">Publish one Weekly Lab Brief with selected papers, decisions, and next experiment ideas.</div></div>
    </div>
  </Panel>

  <section class="block-head">
    <Eyebrow text="Current Status" />
    <h2>Current research status</h2>
  </section>
  <Panel>
    <div class="status-rows">
      <div class="row"><span class="k">Reading</span><span class="v">Semi-supervised behavior recognition and annotation-efficient video learning</span></div>
      <div class="row"><span class="k">Experimenting</span><span class="v on">Wildlife vision and annotation workflow prototypes</span></div>
      <div class="row"><span class="k">Next</span><span class="v">Labeling automation prototype for animal behavior video clips</span></div>
    </div>
  </Panel>

  <section class="block-head">
    <Eyebrow text="Linked Outputs" />
    <h2>Research tracks linked to projects and notes</h2>
    <p>Each track connects the research agenda to project artifacts, lab notes, paper reviews, and small experiments.</p>
  </section>
  <div class="grid cols-3">
    {tracks.map((track) => {
      const trackSlug = getResearchTrackSlug(track);
      return (
        <Card href={`/projects/track/${trackSlug}/`} title={track.data.title} status={track.data.status} statusLabel={track.data.statusLabel} summary={projectCountLabel(trackSlug)} tags={track.data.methods} meta="Track outputs" />
      );
    })}
  </div>
</BaseLayout>
