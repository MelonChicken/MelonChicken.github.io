---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Metabox from '../../components/Metabox.astro';
import RelatedList from '../../components/RelatedList.astro';
import { formatDate, resolveNotes, resolveProject } from '../../lib/content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({ params: { slug: note.data.slug }, props: { note } }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const [project, relatedNotes] = await Promise.all([
  resolveProject(note.data.relatedProject),
  resolveNotes(note.data.relatedNotes),
]);
const isWeeklyBrief = note.data.type === 'weekly-brief';
---

<BaseLayout title={`${note.data.title} - Junu's Lab`}>
  <section class="block-head">
    <Eyebrow text={isWeeklyBrief ? 'Weekly Lab Brief' : 'Lab Note'} />
    <h2>{note.data.title}</h2>
    <p>{note.data.summary}</p>
  </section>

  <div class="home-row detail-layout">
    <article class="panel">
      <Badge status={note.data.status} />
      <Metabox items={[
        { label: 'Type', value: note.data.type },
        { label: 'Date', value: formatDate(note.data.date) },
        { label: 'Read time', value: note.data.readTime ? `${note.data.readTime} min` : undefined },
        { label: 'Domain', value: note.data.domain },
        { label: 'Methods', value: note.data.methods },
      ]} />
      {isWeeklyBrief && (
        <div class="selected-note">
          <b>Research tracking routine</b><br />
          <span class="muted">Selected for review: {note.data.selectedForReview}</span>
        </div>
      )}
      <div class="dblock">
        <Content />
      </div>
    </article>
    <aside class="panel detail-side">
      <nav class="toc" id="noteToc" aria-label="Lab note sections" hidden>
        <h3>On this page</h3>
        <div class="toc-list" id="noteTocList"></div>
        <div class="section-divider"></div>
      </nav>
      <h3>Connections</h3>
      {project && (
        <RelatedList items={[{
          href: `/projects/${project.data.slug}/`,
          title: project.data.title,
          kind: 'Related project',
        }]} />
      )}
      <RelatedList items={relatedNotes.map((related) => ({
        href: `/notes/${related.data.slug}/`,
        title: related.data.title,
        kind: related.data.type,
      }))} />
      {isWeeklyBrief && (
        <Metabox items={[
          { label: 'Tracked fields', value: note.data.trackedFields },
          { label: 'Outputs', value: note.data.outputs },
          { label: 'Next', value: note.data.next },
        ]} />
      )}
    </aside>
  </div>
  <script>
    const content = document.querySelector('.dblock');
    const toc = document.querySelector('#noteToc');
    const tocList = document.querySelector('#noteTocList');
    const headings = Array.from(content?.querySelectorAll('h1, h2') ?? []);

    const slugCounts = new Map();
    const headingLabel = (heading: Element) => {
      const clone = heading.cloneNode(true) as Element;
      clone.querySelectorAll('.katex, script, style').forEach((node) => node.remove());
      return (clone.textContent || heading.textContent || '')
        .replace(/\$\$[\s\S]*?\$\$/g, '')
        .replace(/\$[^$]*\$/g, '')
        .replace(/\\[a-zA-Z]+(?:\{[^}]*\})?/g, '')
        .replace(/\s+/g, ' ')
        .trim();
    };
    const slugify = (value: string | null) => {
      const base = String(value || '')
        .normalize('NFKD')
        .toLowerCase()
        .replace(/[^\w\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-') || 'section';
      const count = slugCounts.get(base) || 0;
      slugCounts.set(base, count + 1);
      return count ? `${base}-${count + 1}` : base;
    };

    if (toc && tocList && headings.length > 0) {
      toc.removeAttribute('hidden');

      for (const heading of headings) {
        const label = headingLabel(heading) || 'Section';
        if (!heading.id) heading.id = slugify(label);
        const link = document.createElement('a');
        link.href = `#${heading.id}`;
        link.textContent = label;
        link.className = heading.tagName === 'H2' ? 'toc-link toc-h2' : 'toc-link toc-h1';
        tocList.append(link);
      }

      const links = Array.from(tocList.querySelectorAll('a'));
      const byId = new Map(links.map((link) => [link.getAttribute('href')?.slice(1), link]));
      const observer = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
        if (!visible) return;

        links.forEach((link) => link.classList.remove('active'));
        byId.get(visible.target.id)?.classList.add('active');
      }, { rootMargin: '-96px 0px -65% 0px', threshold: 0.01 });

      headings.forEach((heading) => observer.observe(heading));
    }
  </script>
</BaseLayout>
