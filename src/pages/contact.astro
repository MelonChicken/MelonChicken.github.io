---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Panel from '../components/Panel.astro';
---

<BaseLayout title="Contact - Junu's Lab">
  <section class="block-head">
    <Eyebrow text="Contact" />
    <h2>Contact and links</h2>
    <p>Use these channels for research, internship, collaboration, or portfolio discussion.</p>
  </section>

  <div class="about-grid">
    <Panel title="Channels">
      <div class="contact-row"><span class="lbl"><span class="platform-icon github-icon" aria-hidden="true">GH</span>GitHub</span><a href="https://github.com/MelonChicken">github.com/MelonChicken</a></div>
      <div class="contact-row"><span class="lbl"><span class="platform-icon linkedin-icon" aria-hidden="true">in</span>LinkedIn</span><a href="https://www.linkedin.com/in/junu-kim-076481344/">junu-kim-076481344</a></div>
      <div class="contact-row"><span class="lbl"><span class="platform-icon email-icon" aria-hidden="true"></span>Outlook Email</span><a href="mailto:junu_kim@outlook.com">junu_kim@outlook.com</a></div>
    </Panel>
    <Panel title="Open to">
      <ul class="plain">
        <li>Undergraduate research / internship opportunities in computer vision, machine learning, and animal behavior analysis</li>
        <li>Collaboration on animal pose estimation, behavior recognition, video understanding, and annotation automation</li>
        <li>Feedback or discussion on research direction, portfolio projects, and lab applications</li>
      </ul>
    </Panel>
  </div>
</BaseLayout>
